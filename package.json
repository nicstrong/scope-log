{
  "name": "scope-log",
  "version": "1.0.2",
  "description": "A drop-in replacement for console.log with hierarchical namespaces and advanced filtering.",
  "private": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vitest",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "rolldown -c rolldown.config.mts && tsc --project tsconfig.dist.json --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "format": "oxfmt --write src",
    "format:check": "oxfmt --check src",
    "knip": "knip",
    "release": "pnpm -r publish && changeset tag",
    "version": "changeset version",
    "ci:build": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run knip && pnpm run build && pnpm run test"
  },
  "keywords": [
    "browser",
    "logging",
    "typescript"
  ],
  "author": "Nic Strong",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicstrong/scope-log.git"
  },
  "homepage": "https://github.com/nicstrong/scope-log#readme.md",
  "bugs": "https://github.com/nicstrong/scope-log/issues",
  "packageManager": "pnpm@10.11.0",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@vitest/coverage-v8": "^4.1.4",
    "knip": "^6.6.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "rolldown": "1.0.0-rc.16",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
